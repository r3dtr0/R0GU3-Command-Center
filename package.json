{
  "name": "r0gu3-command-center",
  "version": "6.0.0",
  "description": "R0GU3 Command Center v6.0 Showroom — The ultimate cyberpunk terminal",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "npm run build:all",
    "build:all": "npm run build:win && npm run build:mac && npm run build:linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "pack": "electron-builder --dir",
    "postinstall": "electron-builder install-app-deps"
  },
  "build": {
    "appId": "com.r0gu3.commandcenter",
    "productName": "R0GU3 Command Center",
    "directories": {
      "output": "dist"
    },
    "files": [
      "R0GU3-Command-Center.html",
      "R0GU3-Command-Center-Standalone.html",
      "electron/**/*",
      "assets/**/*"
    ],
    "mac": {
      "target": ["dmg", "zip"],
      "category": "public.app-category.utilities",
      "icon": "assets/icon.icns"
    },
    "win": {
      "target": ["nsis", "portable"],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": ["AppImage", "deb", "rpm", "tar.gz"],
      "category": "Utility",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico"
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1"
  }
}